FROM alpine:3.20
ARG TARGETARCH
RUN apk add --no-cache ca-certificates
COPY dist/server_linux_${TARGETARCH}*/claude-plane-server /usr/local/bin/
COPY docker-entrypoint.sh /usr/local/bin/
RUN mkdir -p /data && \
    addgroup -S claude && adduser -S claude -G claude && \
    chown claude:claude /data
USER claude
VOLUME /data
EXPOSE 4200 4201
ENTRYPOINT ["docker-entrypoint.sh"]
