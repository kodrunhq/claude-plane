FROM alpine:3.20
ARG TARGETARCH
RUN apk add --no-cache ca-certificates
COPY dist/server_linux_${TARGETARCH}*/claude-plane-server /usr/local/bin/
RUN addgroup -S claude && adduser -S claude -G claude
USER claude
ENTRYPOINT ["claude-plane-server"]
CMD ["serve", "--config", "/etc/claude-plane/server.toml"]
