FROM node:22-alpine AS frontend
WORKDIR /app/web
COPY web/package*.json ./
RUN npm ci
COPY web/ ./
RUN npm run build

FROM golang:1.25-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
COPY --from=frontend /app/internal/server/frontend/dist ./internal/server/frontend/dist

# Build cross-platform agent binaries (embedded in server for /dl/agent/ endpoint)
RUN mkdir -p internal/server/agentdl/binaries && \
    GOOS=linux GOARCH=amd64 CGO_ENABLED=0 go build -o internal/server/agentdl/binaries/claude-plane-agent-linux-amd64 ./cmd/agent && \
    GOOS=linux GOARCH=arm64 CGO_ENABLED=0 go build -o internal/server/agentdl/binaries/claude-plane-agent-linux-arm64 ./cmd/agent && \
    GOOS=darwin GOARCH=amd64 CGO_ENABLED=0 go build -o internal/server/agentdl/binaries/claude-plane-agent-darwin-amd64 ./cmd/agent && \
    GOOS=darwin GOARCH=arm64 CGO_ENABLED=0 go build -o internal/server/agentdl/binaries/claude-plane-agent-darwin-arm64 ./cmd/agent

# Build the server (embeds frontend + agent binaries via go:embed)
RUN CGO_ENABLED=0 go build -o /claude-plane-server ./cmd/server

# Build the bridge
RUN CGO_ENABLED=0 go build -o /claude-plane-bridge ./cmd/bridge

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=builder /claude-plane-server /usr/local/bin/
COPY --from=builder /claude-plane-bridge /usr/local/bin/
COPY docker-entrypoint.sh /usr/local/bin/
RUN mkdir -p /data && \
    addgroup -S claude && adduser -S claude -G claude && \
    chown claude:claude /data
USER claude
VOLUME /data
EXPOSE 4200 4201
ENTRYPOINT ["docker-entrypoint.sh"]
