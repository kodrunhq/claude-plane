# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Claude Code worktrees
.claude/

# Planning and internal docs (not shipped — kept locally for reference)
.planning/
.superpowers/
docs/internal/
docs/plans/
docs/specs/
docs/superpowers/
docs/design/

# Editor/IDE
# .idea/
# .vscode/
.serena/

# Frontend build output (embedded into server binary)
internal/server/frontend/dist/*
!internal/server/frontend/dist/.gitkeep

# Agent binaries (cross-compiled, embedded into server binary)
internal/server/agentdl/binaries/*
!internal/server/agentdl/binaries/.gitkeep

# Built binaries (quickstart, local dev)
claude-plane-server
claude-plane-agent
claude-plane-bridge
/server
/agent
/bridge

# Node modules
node_modules/
web/node_modules/

# Runtime data (quickstart, local dev)
data/
ca/
server-cert/
agent-cert/
agent-data/
*.toml
*.db
*.db-journal
